#!/usr/bin/env bash
# Prune root-only HomeOS audit replay sidecars after their short replay window.
set -euo pipefail

AUDIT_REPLAY_DIR="${HOMEOS_AUDIT_REPLAY_DIR:-/var/lib/homeos/audit-replay}"
RETENTION_DAYS="${HOMEOS_AUDIT_REPLAY_RETENTION_DAYS:-90}"

case "$RETENTION_DAYS" in
  ''|*[!0-9]*) echo "invalid HOMEOS_AUDIT_REPLAY_RETENTION_DAYS: $RETENTION_DAYS" >&2; exit 2 ;;
esac

[ -d "$AUDIT_REPLAY_DIR" ] || exit 0
find "$AUDIT_REPLAY_DIR" -type f -name '*.json' -mtime +"$RETENTION_DAYS" -print -delete
