# ---------- status ----------
cmd_status() {
  bold "== services =="
  systemctl is-active docker tailscaled cockpit.socket casaos caddy smbd nfs-kernel-server homeos-cosmos-docker-shim.service 2>/dev/null | \
    paste <(echo -e "docker\ntailscaled\ncockpit\ncasaos\ncaddy\nsmbd\nnfs\ncosmos-shim") - || true
  bold "== disks =="
  lsblk -o NAME,SIZE,TYPE,MOUNTPOINT,FSTYPE,UUID
  bold "== containers =="
  docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || echo "docker not running"
  bold "== cosmos docker shim =="
  if shim_status="$(systemctl show homeos-cosmos-docker-shim.service -p ActiveState -p SubState -p ActiveEnterTimestamp --value 2>/dev/null)"; then
    awk 'NR==1{print "state: "$0} NR==2{print "substate: "$0} NR==3{print "active since: "$0}' <<<"$shim_status"
  else
    echo "not installed"
  fi
  bold "== GPU =="
  vainfo 2>&1 | grep -E 'Driver version|VAProfile' | head -10 || true
  bold "== tailscale =="
  tailscale status --self 2>/dev/null | head -5 || echo "tailscale not up"
}

# ---------- doctor ----------
cmd_doctor() {
  fails=0
  check() {
    local label="$1"; shift
    if "$@" >/dev/null 2>&1; then printf "  \033[32m✓\033[0m %s\n" "$label"
    else printf "  \033[31m✗\033[0m %s\n" "$label"; fails=$((fails+1)); fi
  }
  bold "== runtime =="
  check "node v24"        bash -c 'node -v | grep -q "^v24\\."'
  check "docker"          docker --version
  check "docker compose"  docker compose version
  check "brew"            sudo -u "$ADMIN_USER" /home/linuxbrew/.linuxbrew/bin/brew --version
  bold "== AI CLIs =="
  for cli in claude codex gemini cursor-agent opencode kimi; do
    check "$cli"          sudo -u "$ADMIN_USER" bash -lc "command -v $cli"
  done
  bold "== services =="
  check "GPU iHD"         bash -c 'vainfo 2>/dev/null | grep -q iHD'
  check "cockpit"         systemctl is-active cockpit.socket
  check "casaos"          systemctl is-active casaos
  check "tailscaled"      systemctl is-active tailscaled
  bold "== HTTP =="
  check "HA :8123"        curl -fsS http://localhost:8123 -o /dev/null
  check "Jellyfin :8096"  curl -fsS http://localhost:8096 -o /dev/null
  check "CasaOS :81"      curl -fsS http://localhost:81 -o /dev/null
  check "Cockpit :9090"   curl -fsSk https://localhost:9090 -o /dev/null
  bold "== tools =="
  for d in hindsight code-review-graph portless claude-context utoo hermes-agent OpenViking oh-my-opencode oh-my-claudecode claude-mem; do
    check "/opt/tools/$d" test -d "/opt/tools/$d"
  done
  echo
  if [ "$fails" -eq 0 ]; then bold "ALL OK"; else bold "$fails check(s) failed"; exit 1; fi
}

# ---------- config rerun-bootstrap ----------
cmd_rerun_bootstrap() {
  need_root
  local diff="ansible-playbook full-bootstrap re-run, args: $*"
  gate "rerun-bootstrap" "$diff" \
    ansible-playbook -i localhost, -c local "$HOMEOS_ROOT/bootstrap/install.yml" "$@"
}

# ---------- secrets ----------
secrets_path() {
  echo "$ADMIN_HOME/.config/homeos/secrets.env"
}

cmd_secrets() {
  local sub="${1:-}"; shift || true
  local f; f="$(secrets_path)"
  [ -f "$f" ] || install -m 600 -o "$ADMIN_USER" -g "$ADMIN_GROUP" /dev/null "$f"
  case "$sub" in
    list) sed 's/=.*/=***/' "$f" ;;
    get)  local k="${1:?KEY required}"; grep -E "^$k=" "$f" | head -1 | cut -d= -f2- ;;
    set)
      local arg="${1:?KEY=VAL or KEY VAL required}"
      local k v
      if [[ "$arg" == *=* ]]; then k="${arg%%=*}"; v="${arg#*=}"; else k="$arg"; v="${2:?VAL required}"; fi
      gate "secrets:set:$k" "set secret key $k (value redacted, length=${#v})" true
      python3 - "$f" "$k" <<'PY'
import pathlib, sys
path = pathlib.Path(sys.argv[1])
key = sys.argv[2]
lines = path.read_text(encoding="utf-8").splitlines() if path.exists() else []
kept = [line for line in lines if not line.startswith(key + "=")]
path.write_text(("\n".join(kept) + "\n") if kept else "", encoding="utf-8")
PY
      echo "${k}=${v}" >> "$f"
      chmod 600 "$f"; chown "$ADMIN_USER:$ADMIN_GROUP" "$f"
      echo "set $k"
      ;;
    unset)
      local k="${1:?KEY required}"
      gate "secrets:unset:$k" "unset secret key $k (value redacted)" true
      python3 - "$f" "$k" <<'PY'
import pathlib, sys
path = pathlib.Path(sys.argv[1])
key = sys.argv[2]
lines = path.read_text(encoding="utf-8").splitlines() if path.exists() else []
kept = [line for line in lines if not line.startswith(key + "=")]
path.write_text(("\n".join(kept) + "\n") if kept else "", encoding="utf-8")
PY
      chmod 600 "$f"; chown "$ADMIN_USER:$ADMIN_GROUP" "$f"
      echo "unset $k"
      ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- nas ----------
cmd_nas() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    list)
      sudo -u "$ADMIN_USER" cat "$NAS_VARS" 2>/dev/null || true
      lsblk -o NAME,LABEL,SIZE,FSTYPE,UUID,MOUNTPOINT
      ;;
    add)
      need_root
      local dev="${1:?device required, e.g. /dev/sdc1}"
      local uuid fstype label
      uuid="$(blkid -s UUID -o value "$dev")"
      fstype="$(blkid -s TYPE -o value "$dev")"
      label="$(blkid -s LABEL -o value "$dev" || true)"
      [ -n "$label" ] || label="nas-$(echo "$uuid" | tr -d - | head -c8)"
      [ -n "$uuid" ] || err "no UUID for $dev"
      gate "nas:add" "device=$dev uuid=$uuid label=$label fstype=$fstype" true
      python3 - <<PY
import yaml, pathlib
p = pathlib.Path("$NAS_VARS")
data = yaml.safe_load(p.read_text()) or {}
disks = data.setdefault("nas_disks", []) or []
if not any(d.get("uuid")=="$uuid" for d in disks):
    disks.append({"uuid":"$uuid","label":"$label","fstype":"$fstype"})
data["nas_disks"]=disks
p.write_text(yaml.safe_dump(data, sort_keys=False))
PY
      ansible-playbook -i localhost, -c local "$HOMEOS_ROOT/bootstrap/install.yml" --tags nas || \
      ansible-playbook -i localhost, -c local "$HOMEOS_ROOT/bootstrap/install.yml"
      echo "share: //$(hostname)/$label"
      ;;
    remove)
      need_root
      local label="${1:?label required}"
      gate "nas:remove" "label=$label (drops mount + share)" true
      python3 - <<PY
import yaml, pathlib
p = pathlib.Path("$NAS_VARS")
data = yaml.safe_load(p.read_text()) or {}
data["nas_disks"] = [d for d in (data.get("nas_disks") or []) if d.get("label")!="$label"]
p.write_text(yaml.safe_dump(data, sort_keys=False))
PY
      systemctl disable --now "srv-nas-${label}.mount" 2>/dev/null || true
      ansible-playbook -i localhost, -c local "$HOMEOS_ROOT/bootstrap/install.yml" || true
      ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- stack ----------
cmd_stack() {
  local sub="${1:-list}"
  if [ "$sub" = "list" ]; then
    for dir in /opt/stacks/*; do
      [ -f "$dir/docker-compose.yml" ] || continue
      basename "$dir"
    done
    return 0
  fi
  local name="${2:?stack name}"
  local dir="/opt/stacks/$name"
  [ -d "$dir" ] || err "no stack at $dir"
  case "$sub" in
    up)      gate "stack:up:$name"      "compose up at $dir"            bash -c 'cd "$1" && docker compose up -d' _ "$dir" ;;
    down)    gate "stack:down:$name"    "compose down at $dir"          bash -c 'cd "$1" && docker compose down' _ "$dir" ;;
    restart) gate "stack:restart:$name" "compose restart at $dir"       bash -c 'cd "$1" && docker compose restart' _ "$dir" ;;
    update)  gate "stack:update:$name"  "compose pull+recreate at $dir" bash -c 'cd "$1" && docker compose pull && docker compose up -d' _ "$dir" ;;
    logs)    (cd "$dir" && docker compose logs -f) ;;
    ps)      (cd "$dir" && docker compose ps) ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- net ----------
cmd_net() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    tailscale-up)
      need_root
      local key=""
      while [ $# -gt 0 ]; do
        case "$1" in --auth-key) key="$2"; shift 2 ;; *) shift ;; esac
      done
      if [ -n "$key" ]; then
        tailscale up --ssh --accept-routes --auth-key "$key"
      else
        tailscale up --ssh --accept-routes
      fi
      tailscale status
      local fqdn; fqdn="$(tailscale status --json 2>/dev/null | python3 -c 'import sys,json;d=json.load(sys.stdin);print(d["Self"]["DNSName"].rstrip(".") if d.get("Self") else "")' 2>/dev/null || true)"
      [ -n "$fqdn" ] && echo "HOMEOS_TAILNET=$fqdn" > /etc/default/caddy
      systemctl reload caddy 2>/dev/null || true
      ;;
    tailscale-down)
      need_root
      gate "net:tailscale-down" "tailscale down" tailscale down
      ;;
    caddy-reload)
      need_root
      systemctl reload caddy
      ;;
    caddy-test)
      caddy validate --config /etc/caddy/Caddyfile
      ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- backup ----------
backup_require_env() {
  [ -f "$BACKUP_ENV" ] || err "no $BACKUP_ENV — rerun bootstrap"
  # shellcheck disable=SC1090
  source "$BACKUP_ENV"
  [ -n "${RESTIC_REPOSITORY:-}" ] || err "backup target unset — run: sudo homeos config backup target set /srv/nas/<label>"
  export RESTIC_REPOSITORY RESTIC_PASSWORD_FILE
}

backup_write_target() {
  local path="$1"
  python3 - "$BACKUP_ENV" "$path" <<'PY'
import pathlib, sys
env_path = pathlib.Path(sys.argv[1])
target = sys.argv[2]
lines = env_path.read_text(encoding="utf-8").splitlines() if env_path.exists() else []
found = False
out = []
for line in lines:
    if line.startswith("RESTIC_REPOSITORY="):
        out.append(f"RESTIC_REPOSITORY={target}")
        found = True
    else:
        out.append(line)
if not found:
    out.append(f"RESTIC_REPOSITORY={target}")
env_path.write_text("\n".join(out) + "\n", encoding="utf-8")
PY
}

cmd_backup() {
  local sub="${1:?target|run|snapshots|forget|restore}"; shift || true
  case "$sub" in
    target)
      local action="${1:?set|show}"; shift || true
      case "$action" in
        set)
          local path="${1:?path required}"
          need_root
          mkdir -p "$(dirname "$BACKUP_ENV")"
          [ -f "$BACKUP_ENV" ] || printf 'RESTIC_REPOSITORY=\nRESTIC_PASSWORD_FILE=/etc/homeos/restic.pass\nBACKUP_PATHS="/srv /opt/stacks /home/admin"\n' > "$BACKUP_ENV"
          chmod 0600 "$BACKUP_ENV"
          mkdir -p "$path"
          backup_write_target "$path"
          backup_require_env
          restic snapshots >/dev/null 2>&1 || restic init
          echo "backup target: $path"
          ;;
        show)
          # shellcheck disable=SC1090
          [ -f "$BACKUP_ENV" ] && source "$BACKUP_ENV"
          echo "backup target: ${RESTIC_REPOSITORY:-unset}"
          ;;
        *) usage; exit 2 ;;
      esac
      ;;
    run)
      need_root
      /usr/local/sbin/homeos-backup
      ;;
    snapshots)
      backup_require_env
      restic snapshots
      ;;
    forget)
      need_root
      backup_require_env
      restic forget --keep-daily 7 --keep-weekly 4 --keep-monthly 6 --prune
      ;;
    restore)
      need_root
      local snapshot="${1:?snapshot required}" path="${2:?restore target path required}"
      backup_require_env
      mkdir -p "$path"
      restic restore "$snapshot" --target "$path"
      ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- portal ----------
cmd_portal() {
  local sub="${1:-status}"
  local flag="/var/lib/homeos/portal.enabled"
  local dir="/opt/stacks/portal"
  case "$sub" in
    on)
      need_root
      [ -d "$dir" ] || err "portal stack not installed at $dir — run rerun-bootstrap"
      mkdir -p "$(dirname "$flag")"
      gate "portal:on" "enable portal flag + docker compose up at $dir" true
      touch "$flag"
      (cd "$dir" && docker compose up -d)
      bold "portal up. Tailscale URLs:"
      echo "  https://portal.<tailnet>.ts.net   dashboard"
      echo "  https://chat.<tailnet>.ts.net     Open WebUI"
      echo "  https://stacks.<tailnet>.ts.net   Dockge"
      echo "  https://files.<tailnet>.ts.net    Filebrowser"
      ;;
    off)
      need_root
      rm -f "$flag"
      [ -d "$dir" ] && (cd "$dir" && docker compose down) || true
      bold "portal down."
      ;;
    status)
      if [ -f "$flag" ]; then echo "flag: enabled"; else echo "flag: disabled"; fi
      docker ps --filter "label=com.docker.compose.project=portal" \
        --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || true
      ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- cosmos ----------
cmd_cosmos() {
  local sub="${1:-status}"
  local flag="/var/lib/homeos/cosmos.enabled"
  local dir="/opt/stacks/cosmos"
  local shim_unit="homeos-cosmos-docker-shim.service"
  local stack_unit="homeos-cosmos.service"
  local legacy_audit_unit="homeos-cosmos-audit.service"
  case "$sub" in
    on)
      need_root
      [ -d "$dir" ] || err "cosmos stack not installed at $dir — run rerun-bootstrap"
      gate "cosmos:on" "enable cosmos flag + systemd-managed compose up at $dir through Docker socket shim" \
        sh -c "mkdir -p '$(dirname "$flag")' && (systemctl disable --now '$legacy_audit_unit' 2>/dev/null || true) && systemctl enable --now '$shim_unit' && touch '$flag' && systemctl enable --now '$stack_unit'"
      bold "cosmos up. URL:"
      echo "  https://cosmos.<tailnet>.ts.net"
      echo "  first-run setup runs in browser; create admin account immediately."
      ;;
    off)
      need_root
      gate "cosmos:off" "disable cosmos flag + stop systemd-managed Cosmos stack and Docker socket shim" \
        sh -c "rm -f '$flag'; systemctl disable --now '$stack_unit' 2>/dev/null || true; [ -d '$dir' ] && (cd '$dir' && docker compose down) || true; systemctl disable --now '$shim_unit' 2>/dev/null || true; systemctl disable --now '$legacy_audit_unit' 2>/dev/null || true"
      bold "cosmos down."
      ;;
    status)
      if [ -f "$flag" ]; then echo "flag: enabled"; else echo "flag: disabled"; fi
      docker ps --filter "name=cosmos" \
        --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || true
      systemctl --no-pager --lines=0 status "$stack_unit" 2>/dev/null | sed -n '1,3p' || true
      systemctl --no-pager --lines=0 status "$shim_unit" 2>/dev/null | sed -n '1,3p' || true
      ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- gate ----------
cmd_gate() {
  local sub="${1:?set|show}"; shift || true
  case "$sub" in
    set)
      need_root
      local p="${1:?provider required: claude|openai|openrouter|ollama|none}"
      case "$p" in claude|openai|openrouter|ollama|none) ;; *) err "unknown provider $p" ;; esac
      mkdir -p /var/lib/homeos
      echo "$p" > "$GATE_PROVIDER_FILE"
      bold "AI review gate provider: $p"
      ;;
    show)
      echo "provider: $(ai_provider)"
      ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- audit ----------
audit_resolve_sidecar() {
  # audit_resolve_sidecar <id_or_hash> -> prints: <line_no> TAB <sidecar_path> TAB <orig_cmd>
  local selector="${1:?id_or_hash required}"
  python3 - "$AUDIT_LOG" "$AUDIT_REPLAY_DIR" "$selector" <<'PY'
import json, pathlib, sys
log_path = pathlib.Path(sys.argv[1])
replay_dir = pathlib.Path(sys.argv[2])
selector = sys.argv[3]
if not log_path.exists():
    print("no audit entries yet", file=sys.stderr)
    sys.exit(3)
entries = []
with log_path.open(encoding="utf-8") as fh:
    for lineno, raw in enumerate(fh, 1):
        try:
            entry = json.loads(raw)
        except Exception:
            continue
        entries.append((lineno, entry))
matches = []
if selector.isdigit():
    wanted = int(selector)
    matches.extend((lineno, entry) for lineno, entry in entries if lineno == wanted)
matches.extend((lineno, entry) for lineno, entry in entries if entry.get("diff_hash") == selector or entry.get("sidecar_id") == selector)
seen = set()
matches = [(lineno, entry) for lineno, entry in matches if not (lineno in seen or seen.add(lineno))]
if not matches:
    print(f"no audit entry matches {selector}", file=sys.stderr)
    sys.exit(3)
if len(matches) > 1:
    ids = ", ".join(str(lineno) for lineno, _ in matches)
    print(f"ambiguous audit selector {selector}; use one of these line-number IDs: {ids}", file=sys.stderr)
    sys.exit(4)
lineno, entry = matches[0]
sidecar_id = entry.get("sidecar_id") or (str(entry.get("diff_hash", "")) + ".json")
sidecar_id = pathlib.PurePath(sidecar_id).name
sidecar_path = replay_dir / sidecar_id
orig_cmd = str(entry.get("cmd", ""))
print(f"{lineno}\t{sidecar_path}\t{orig_cmd}")
PY
}

cmd_audit() {
  local sub="${1:-tail}"; shift || true
  case "$sub" in
    tail)
      local n=20
      [ "${1:-}" = "-n" ] && n="$2"
      [ -f "$AUDIT_LOG" ] || { echo "no audit entries yet"; return 0; }
      tail -n "$n" "$AUDIT_LOG" | python3 -c '
import sys, json
for line in sys.stdin:
  try:
    e = json.loads(line)
    print(f"{e[\"ts\"]}  {e[\"user\"]:>10}  {e[\"cmd\"]:<28}  verdict={e[\"verdict\"][:40]:<40}  choice={e[\"choice\"]}")
  except Exception:
    print(line.rstrip())
'
      ;;
    search)
      local pat="${1:?pattern required}"
      [ -f "$AUDIT_LOG" ] || { echo "no audit entries yet"; return 0; }
      grep -i -- "$pat" "$AUDIT_LOG" || true
      ;;
    show)
      local selector="${1:?id_or_hash required}"
      [ -f "$AUDIT_LOG" ] || { echo "no audit entries yet"; return 0; }
      python3 - "$AUDIT_LOG" "$AUDIT_REPLAY_DIR" "$selector" "$(id -u)" <<'PY'
import json, pathlib, sys
log_path = pathlib.Path(sys.argv[1])
replay_dir = pathlib.Path(sys.argv[2])
selector = sys.argv[3]
is_root = sys.argv[4] == "0"
lines = []
with log_path.open(encoding="utf-8") as fh:
    for lineno, raw in enumerate(fh, 1):
        try:
            entry = json.loads(raw)
        except Exception:
            continue
        lines.append((lineno, raw.rstrip("\n"), entry))
matches = []
if selector.isdigit():
    wanted = int(selector)
    matches.extend(item for item in lines if item[0] == wanted)
matches.extend(item for item in lines if item[2].get("diff_hash") == selector or item[2].get("sidecar_id") == selector)
seen = set()
matches = [item for item in matches if not (item[0] in seen or seen.add(item[0]))]
if not matches:
    print(f"no audit entry matches {selector}", file=sys.stderr)
    sys.exit(3)
if len(matches) > 1:
    ids = ", ".join(str(item[0]) for item in matches)
    print(f"ambiguous audit selector {selector}; use one of these line-number IDs: {ids}", file=sys.stderr)
    sys.exit(4)
lineno, raw, entry = matches[0]
print(f"audit[{lineno}]: {raw}")
sidecar_id = entry.get("sidecar_id") or (str(entry.get("diff_hash", "")) + ".json")
sidecar_id = pathlib.PurePath(sidecar_id).name
sidecar_path = replay_dir / sidecar_id
if not is_root:
    print("sidecar: root-only (run sudo homeos audit show to inspect replay payload)")
elif not sidecar_path.exists():
    print(f"sidecar: missing or pruned ({sidecar_id})")
else:
    try:
        payload = json.loads(sidecar_path.read_text(encoding="utf-8"))
        print("sidecar:")
        print(json.dumps(payload, indent=2, sort_keys=True))
    except Exception as exc:
        print(f"sidecar: unreadable ({exc})", file=sys.stderr)
        sys.exit(5)
PY
      ;;
    replay)
      local selector="${1:?id_or_hash required}"
      local resolved line_no sidecar_path orig_cmd argv_file env_file replay_cmd
      resolved="$(audit_resolve_sidecar "$selector")" || return $?
      line_no="${resolved%%$'\t'*}"
      replay_cmd="${resolved##*$'\t'}"
      sidecar_path="${resolved#*$'\t'}"
      sidecar_path="${sidecar_path%$'\t'*}"
      if [ "$(id -u)" -ne 0 ] && [ ! -r "$sidecar_path" ]; then
        err "audit replay sidecar is root-only; run with sudo"
      fi
      [ -f "$sidecar_path" ] || err "audit replay sidecar missing or pruned for audit[$line_no]: $sidecar_path"
      [ -r "$sidecar_path" ] || err "audit replay sidecar is root-only; run with sudo"
      argv_file="$(mktemp)"
      python3 - "$sidecar_path" > "$argv_file" <<'PY'
import json, pathlib, sys
payload = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
argv = payload.get("argv")
if not isinstance(argv, list) or not all(isinstance(x, str) for x in argv):
    print("sidecar has no replayable argv", file=sys.stderr)
    sys.exit(6)
if len(argv) >= 2 and argv[0] == "audit" and argv[1] == "replay":
    print("refusing to replay an audit replay command", file=sys.stderr)
    sys.exit(7)
sys.stdout.buffer.write(b"\0".join(x.encode() for x in argv) + b"\0")
PY
      env_file="$(mktemp)"
      python3 - "$sidecar_path" > "$env_file" <<'PY'
import json, pathlib, sys
payload = json.loads(pathlib.Path(sys.argv[1]).read_text(encoding="utf-8"))
replay_env = payload.get("replay_env", {})
allowed = ["HOMEOS_ADMIN_USER", "HOMEOS_ADMIN_GROUP", "HOMEOS_ADMIN_HOME", "HOMEOS_ROOT"]
out = []
for key in allowed:
    val = replay_env.get(key)
    if isinstance(val, str) and val:
        out.append(f"{key}={val}".encode())
sys.stdout.buffer.write(b"\0".join(out) + (b"\0" if out else b""))
PY
      local replay_argv=() replay_env=()
      while IFS= read -r -d '' arg; do replay_argv+=("$arg"); done < "$argv_file"
      while IFS= read -r -d '' kv; do replay_env+=("$kv"); done < "$env_file"
      rm -f "$argv_file" "$env_file"
      [ "${#replay_argv[@]}" -gt 0 ] || err "sidecar has empty replay argv"
      env -u HOMEOS_NO_REVIEW \
        HOMEOS_REPLAY_AUDIT_CMD="audit:replay:$replay_cmd" \
        "${replay_env[@]}" \
        "$0" "${replay_argv[@]}"
      ;;
    cosmos-events)
      local n=20
      [ "${1:-}" = "-n" ] && n="${2:?count required}"
      [ -f "$AUDIT_LOG" ] || { echo "no audit entries yet"; return 0; }
      python3 - "$AUDIT_LOG" "$n" <<'PY'
import json, sys
path, count = sys.argv[1], int(sys.argv[2])
entries = []
with open(path, encoding="utf-8") as fh:
    for line in fh:
        try:
            entry = json.loads(line)
        except Exception:
            continue
        if entry.get("source") == "cosmos-docker-shim" or (
            str(entry.get("cmd", "")).startswith("cosmos:")
            and entry.get("user") == "cosmos"
            and entry.get("verdict") == "BYPASS"
        ):
            entries.append(entry)
for e in entries[-count:]:
    print(f"{e.get('ts','')}  {e.get('cmd',''):<28}  verdict={e.get('verdict','')}  hash={e.get('diff_hash','')}  {e.get('summary','')}")
PY
      ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- install ----------
INSTALLERS=(ollama mcp-hub media-stack offsite-backup ai-keys monitoring image-gen voice)

install_flag() { echo "$INSTALLED_DIR/$1.installed"; }
is_installed() { [ -f "$(install_flag "$1")" ]; }
mark_installed() { mkdir -p "$INSTALLED_DIR"; touch "$(install_flag "$1")"; }

cmd_install() {
  local feat="${1:-}"; shift || true
  if [ "$feat" = "--list" ] || [ -z "$feat" ]; then
    bold "available installers:"
    for f in "${INSTALLERS[@]}"; do
      if is_installed "$f"; then echo "  [x] $f"; else echo "  [ ] $f"; fi
    done
    echo
    echo "usage: sudo homeos install <feature> [--reconfigure]"
    return 0
  fi
  local reconfigure=0
  [ "${1:-}" = "--reconfigure" ] && reconfigure=1
  need_root
  if is_installed "$feat" && [ "$reconfigure" -eq 0 ]; then
    bold "$feat already installed (use --reconfigure to redo)"
    return 0
  fi
  local script="/opt/homeos/bootstrap/installers/${feat}.sh"
  [ -x "$script" ] || err "no installer at $script"
  gate "install:$feat" "feature=$feat reconfigure=$reconfigure" \
    bash "$script" $([ "$reconfigure" -eq 1 ] && echo "--reconfigure")
  mark_installed "$feat"
  bold "installed: $feat"
}

# ---------- secure ----------
cmd_secure() {
  need_root
  local ssh_dir="$ADMIN_HOME/.ssh"
  local ak="$ssh_dir/authorized_keys"
  if [ ! -s "$ak" ]; then
    err "no $ak — upload your pubkey first (scp ~/.ssh/id_ed25519.pub admin@host:.ssh/authorized_keys)"
  fi
  if ! grep -qE '(^|[[:space:]])(ssh-(rsa|ed25519|dss)|ecdsa-sha2-[^[:space:]]+)[[:space:]]' "$ak"; then
    err "$ak has no recognizable public key line — refusing to lock"
  fi
  install -d -m 700 -o "$ADMIN_USER" -g "$ADMIN_GROUP" "$ssh_dir"
  chown "$ADMIN_USER:$ADMIN_GROUP" "$ak"
  chmod 600 "$ak"

  local conf=/etc/ssh/sshd_config.d/99-homeos.conf
  mkdir -p "$(dirname "$conf")"
  [ -f "$conf" ] || touch "$conf"
  local backup; backup="$(mktemp)"
  cp -a "$conf" "$backup"
  sed -i 's/^PasswordAuthentication .*/PasswordAuthentication no/' "$conf"
  if ! grep -q '^PasswordAuthentication no' "$conf"; then
    echo "PasswordAuthentication no" >> "$conf"
  fi
  if ! sshd -t; then
    cp -a "$backup" "$conf"
    rm -f "$backup"
    err "sshd config invalid — restored previous config and kept password auth unchanged"
  fi
  local sshd_effective
  sshd_effective="$(sshd -T -C "user=$ADMIN_USER,host=localhost,addr=127.0.0.1" 2>/dev/null || true)"
  if ! grep -q '^pubkeyauthentication yes$' <<<"$sshd_effective"; then
    cp -a "$backup" "$conf"
    rm -f "$backup"
    err "sshd effective config does not allow public-key auth for $ADMIN_USER — refusing to lock"
  fi
  if ! grep '^authorizedkeysfile ' <<<"$sshd_effective" | grep -Eq '(^|[[:space:]])(%h/)?\.ssh/authorized_keys([[:space:]]|$)'; then
    cp -a "$backup" "$conf"
    rm -f "$backup"
    err "sshd effective config does not read .ssh/authorized_keys for $ADMIN_USER — refusing to lock"
  fi
  rm -f "$backup"
  systemctl restart ssh
  passwd -l "$ADMIN_USER"
  bold "secured: password auth off, $ADMIN_USER password locked"
  echo "validated $ak permissions, sshd public-key auth, and authorized-keys lookup before locking"
  echo "to undo: sudo passwd -u $ADMIN_USER && edit $conf"
}

# ---------- dispatch ----------
main() {
  HOMEOS_ORIGINAL_ARGV_JSON="$(json_argv "$@")"
  export HOMEOS_ORIGINAL_ARGV_JSON
  local top="${1:-}"; shift || true
  case "$top" in
    status)  cmd_status "$@" ;;
    doctor)  cmd_doctor "$@" ;;
    secure)  cmd_secure "$@" ;;
    install) cmd_install "$@" ;;
    audit)   cmd_audit "$@" ;;
    config)
      local section="${1:-}"; shift || true
      case "$section" in
        rerun-bootstrap) cmd_rerun_bootstrap "$@" ;;
        secrets)         cmd_secrets "$@" ;;
        nas)             cmd_nas "$@" ;;
        stack)           cmd_stack "$@" ;;
        net)             cmd_net "$@" ;;
        backup)          cmd_backup "$@" ;;
        portal)          cmd_portal "$@" ;;
        cosmos)          cmd_cosmos "$@" ;;
        gate)            cmd_gate "$@" ;;
        *) usage; exit 2 ;;
      esac
      ;;
    ""|-h|--help|help) usage ;;
    *) usage; exit 2 ;;
  esac
}
main "$@"
