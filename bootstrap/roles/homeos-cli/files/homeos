# ---------- install ----------
INSTALLERS=(ollama mcp-hub media-stack offsite-backup ai-keys monitoring image-gen voice)

install_flag() { echo "$INSTALLED_DIR/$1.installed"; }
is_installed() { [ -f "$(install_flag "$1")" ]; }
mark_installed() { mkdir -p "$INSTALLED_DIR"; touch "$(install_flag "$1")"; }

cmd_install() {
  local feat="${1:-}"; shift || true
  if [ "$feat" = "--list" ] || [ -z "$feat" ]; then
    bold "available installers:"
    for f in "${INSTALLERS[@]}"; do
      if is_installed "$f"; then echo "  [x] $f"; else echo "  [ ] $f"; fi
    done
    echo
    echo "usage: sudo homeos install <feature> [--reconfigure]"
    return 0
  fi
  local reconfigure=0
  [ "${1:-}" = "--reconfigure" ] && reconfigure=1
  need_root
  if is_installed "$feat" && [ "$reconfigure" -eq 0 ]; then
    bold "$feat already installed (use --reconfigure to redo)"
    return 0
  fi
  local script="/opt/homeos/bootstrap/installers/${feat}.sh"
  [ -x "$script" ] || err "no installer at $script"
  gate "install:$feat" "feature=$feat reconfigure=$reconfigure" \
    bash "$script" $([ "$reconfigure" -eq 1 ] && echo "--reconfigure")
  mark_installed "$feat"
  bold "installed: $feat"
}

# ---------- secure ----------
cmd_secure() {
  need_root
  local ssh_dir="$ADMIN_HOME/.ssh"
  local ak="$ssh_dir/authorized_keys"
  if [ ! -s "$ak" ]; then
    err "no $ak — upload your pubkey first (scp ~/.ssh/id_ed25519.pub admin@host:.ssh/authorized_keys)"
  fi
  if ! grep -qE '(^|[[:space:]])(ssh-(rsa|ed25519|dss)|ecdsa-sha2-[^[:space:]]+)[[:space:]]' "$ak"; then
    err "$ak has no recognizable public key line — refusing to lock"
  fi
  install -d -m 700 -o "$ADMIN_USER" -g "$ADMIN_GROUP" "$ssh_dir"
  chown "$ADMIN_USER:$ADMIN_GROUP" "$ak"
  chmod 600 "$ak"

  local conf=/etc/ssh/sshd_config.d/99-homeos.conf
  mkdir -p "$(dirname "$conf")"
  [ -f "$conf" ] || touch "$conf"
  local backup; backup="$(mktemp)"
  cp -a "$conf" "$backup"
  sed -i 's/^PasswordAuthentication .*/PasswordAuthentication no/' "$conf"
  if ! grep -q '^PasswordAuthentication no' "$conf"; then
    echo "PasswordAuthentication no" >> "$conf"
  fi
  if ! sshd -t; then
    cp -a "$backup" "$conf"
    rm -f "$backup"
    err "sshd config invalid — restored previous config and kept password auth unchanged"
  fi
  local sshd_effective
  sshd_effective="$(sshd -T -C "user=$ADMIN_USER,host=localhost,addr=127.0.0.1" 2>/dev/null || true)"
  if ! grep -q '^pubkeyauthentication yes$' <<<"$sshd_effective"; then
    cp -a "$backup" "$conf"
    rm -f "$backup"
    err "sshd effective config does not allow public-key auth for $ADMIN_USER — refusing to lock"
  fi
  if ! grep '^authorizedkeysfile ' <<<"$sshd_effective" | grep -Eq '(^|[[:space:]])(%h/)?\.ssh/authorized_keys([[:space:]]|$)'; then
    cp -a "$backup" "$conf"
    rm -f "$backup"
    err "sshd effective config does not read .ssh/authorized_keys for $ADMIN_USER — refusing to lock"
  fi
  rm -f "$backup"
  systemctl restart ssh
  passwd -l "$ADMIN_USER"
  bold "secured: password auth off, $ADMIN_USER password locked"
  echo "validated $ak permissions, sshd public-key auth, and authorized-keys lookup before locking"
  echo "to undo: sudo passwd -u $ADMIN_USER && edit $conf"
}


# ---------- init / upgrade / log / diag ----------
cmd_init() {
  local dry=0 yes=0 skip_secure=0 skip_tailscale=0 skip_secrets=0 skip_nas=0 skip_backup=0 auth_key="" nas_device="" backup_target=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run) dry=1; shift ;;
      --yes) yes=1; shift ;;
      --skip-secure) skip_secure=1; shift ;;
      --skip-tailscale) skip_tailscale=1; shift ;;
      --skip-secrets) skip_secrets=1; shift ;;
      --skip-nas) skip_nas=1; shift ;;
      --skip-backup) skip_backup=1; shift ;;
      --auth-key) auth_key="${2:?auth key required}"; shift 2 ;;
      --nas-device) nas_device="${2:?device required}"; shift 2 ;;
      --backup-target) backup_target="${2:?target required}"; shift 2 ;;
      *) usage; exit 2 ;;
    esac
  done
  bold "HomeOS init plan"
  echo "  bootstrap state check"
  [ "$skip_secure" = 1 ] || echo "  secure SSH"
  [ "$skip_tailscale" = 1 ] || echo "  connect Tailscale"
  [ "$skip_secrets" = 1 ] || echo "  configure selected secrets"
  [ "$skip_nas" = 1 ] || echo "  add NAS disk"
  [ "$skip_backup" = 1 ] || echo "  configure backup target"
  [ "$dry" = 1 ] && return 0
  need_root
  if [ -f "$BOOTSTRAP_FAILED_MARKER" ]; then err "firstboot failed; run: sudo homeos log firstboot --lines 200 and homeos diag"; fi
  if [ ! -f "$BOOTSTRAPPED_MARKER" ]; then
    local state; state="$(systemctl is-active homeos-firstboot.service 2>/dev/null || true)"
    [ "$state" = "active" ] && err "firstboot is still running; inspect with: homeos log firstboot --follow"
    warn "bootstrap completion marker missing; continuing only if you confirm"
    if [ "$yes" = 1 ]; then
      warn "continuing because --yes was provided"
    else
      require_tty_for_interactive "homeos init bootstrap confirmation"
      confirm_prompt "continue init anyway?" n || err "aborted"
    fi
  fi
  if [ "$skip_secure" != 1 ]; then
    if [ "$yes" = 1 ]; then
      cmd_secure
    else
      require_tty_for_interactive "homeos init secure prompt"
      confirm_prompt "secure SSH now?" y && cmd_secure
    fi
  fi
  if [ "$skip_tailscale" != 1 ]; then
    if tailscale status --self >/dev/null 2>&1; then echo "tailscale: already up"; else
      if [ -z "$auth_key" ]; then
        if [ "$yes" = 1 ] || [ ! -t 0 ]; then
          warn "tailscale auth key not provided; skipping Tailscale setup"
        else
          auth_key="$(prompt_secret 'Tailscale auth key (or Ctrl-C to skip)')"
        fi
      fi
      [ -n "$auth_key" ] && cmd_net tailscale-up --auth-key "$auth_key"
    fi
  fi
  if [ "$skip_secrets" != 1 ] && [ "$yes" != 1 ]; then
    require_tty_for_interactive "homeos init secrets prompt"
    while confirm_prompt "set a HomeOS secret?" n; do
      local key val
      key="$(prompt_value 'secret key')"; val="$(prompt_secret 'secret value')"
      cmd_secrets set "$key" "$val"
    done
  fi
  if [ "$skip_nas" != 1 ]; then
    if [ -z "$nas_device" ] && [ "$yes" != 1 ]; then
      require_tty_for_interactive "homeos init NAS prompt"
      confirm_prompt "add a NAS disk now?" n && nas_device="$(prompt_value 'NAS block device')" || true
    fi
    [ -n "$nas_device" ] && cmd_nas add "$nas_device"
  fi
  if [ "$skip_backup" != 1 ]; then
    if [ -z "$backup_target" ] && [ "$yes" != 1 ]; then
      require_tty_for_interactive "homeos init backup prompt"
      confirm_prompt "configure a backup target now?" n && backup_target="$(prompt_value 'backup target path')" || true
    fi
    [ -n "$backup_target" ] && cmd_backup target set "$backup_target"
  fi
}

cmd_upgrade() {
  local check=0 skip_apt=0 skip_docker=0 skip_brew=0 skip_doctor=0 fails=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --check) check=1; shift ;;
      --skip-apt) skip_apt=1; shift ;;
      --skip-docker) skip_docker=1; shift ;;
      --skip-brew) skip_brew=1; shift ;;
      --skip-doctor) skip_doctor=1; shift ;;
      *) usage; exit 2 ;;
    esac
  done
  if [ "$check" = 1 ]; then
    bold "== upgrade check =="
    [ "$skip_apt" = 1 ] || { echo "apt:"; apt-get -s upgrade 2>/dev/null | sed -n '1,20p' || warn "apt simulation unavailable"; }
    if [ "$skip_docker" != 1 ]; then
      echo "stacks:"; for dir in /opt/stacks/*; do [ -f "$dir/docker-compose.yml" ] && echo "  $(basename "$dir")"; done
    fi
    [ "$skip_brew" = 1 ] || { [ -x /home/linuxbrew/.linuxbrew/bin/brew ] && echo "brew: installed" || echo "brew: not installed"; }
    return 0
  fi
  need_root
  if [ "$skip_apt" != 1 ]; then
    gate "upgrade:apt" "apt-get update && apt-get upgrade -y" bash -c 'apt-get update && DEBIAN_FRONTEND=noninteractive apt-get upgrade -y' || fails=$((fails+1))
  fi
  if [ "$skip_docker" != 1 ]; then
    for dir in /opt/stacks/*; do
      [ -f "$dir/docker-compose.yml" ] || continue
      local name; name="$(basename "$dir")"
      validate_stack_name "$name"
      gate "upgrade:docker:$name" "record digests, preflight, pull+recreate stack $name" stack_update_impl "$name" "$dir" || { warn "stack update failed: $name"; fails=$((fails+1)); }
    done
  fi
  if [ "$skip_brew" != 1 ] && [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
    gate "upgrade:brew" "brew update" sudo -u "$ADMIN_USER" /home/linuxbrew/.linuxbrew/bin/brew update || fails=$((fails+1))
    gate "upgrade:brew-upgrade" "brew upgrade" sudo -u "$ADMIN_USER" /home/linuxbrew/.linuxbrew/bin/brew upgrade || fails=$((fails+1))
  fi
  [ -f /var/run/reboot-required ] && warn "reboot required"
  [ "$skip_doctor" = 1 ] || cmd_doctor || fails=$((fails+1))
  [ "$fails" -eq 0 ] || err "$fails upgrade step(s) failed"
}

cmd_log() {
  local lines=100 follow=0 target="summary" follow_flag=() tail_follow=() compose_follow=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --lines|-n) lines="${2:?line count required}"; shift 2 ;;
      --follow|-f) follow=1; shift ;;
      --help|-h) echo "usage: homeos log [--lines N] [--follow] TARGET"; return 0 ;;
      *) target="$1"; shift ;;
    esac
  done
  [[ "$lines" =~ ^[0-9]+$ ]] || err "--lines must be numeric"
  if [ "$follow" = 1 ]; then
    follow_flag=(-f)
    tail_follow=(-f)
    compose_follow=(-f)
  fi
  case "$target" in
    summary) journalctl -n "$lines" --no-pager "${follow_flag[@]}" ;;
    bootstrap) tail "${tail_follow[@]}" -n "$lines" /var/log/homeos-bootstrap.log ;;
    firstboot) journalctl -u homeos-firstboot.service -n "$lines" --no-pager "${follow_flag[@]}" ;;
    backup) tail "${tail_follow[@]}" -n "$lines" /var/log/homeos-backup.log ;;
    audit) tail "${tail_follow[@]}" -n "$lines" "$AUDIT_LOG" ;;
    caddy) journalctl -u caddy -n "$lines" --no-pager "${follow_flag[@]}" ;;
    docker) journalctl -u docker -n "$lines" --no-pager "${follow_flag[@]}" ;;
    tailscale) journalctl -u tailscaled -n "$lines" --no-pager "${follow_flag[@]}" ;;
    cosmos) journalctl -u homeos-cosmos.service -u homeos-cosmos-docker-shim.service -n "$lines" --no-pager "${follow_flag[@]}" ;;
    portal) (cd /opt/stacks/portal && docker compose logs "${compose_follow[@]}" --tail "$lines") ;;
    stack:*) local name="${target#stack:}"; validate_stack_name "$name"; (cd "/opt/stacks/$name" && docker compose logs "${compose_follow[@]}" --tail "$lines") ;;
    *) usage; exit 2 ;;
  esac
}

cmd_diag() {
  local fails=0
  diag_ok(){ printf '  \033[32mOK\033[0m %s\n' "$*"; }
  diag_warn(){ printf '  \033[33mWARN\033[0m %s\n' "$*"; }
  diag_fail(){ printf '  \033[31mFAIL\033[0m %s\n' "$*"; fails=$((fails+1)); }
  bold "== bootstrap =="
  if [ -f "$BOOTSTRAP_FAILED_MARKER" ]; then diag_fail "firstboot failed; run sudo homeos log firstboot --lines 200"; elif [ -f "$BOOTSTRAPPED_MARKER" ]; then diag_ok "bootstrap complete"; else diag_warn "bootstrap marker missing"; fi
  bold "== systemd =="
  systemctl --failed --no-legend 2>/dev/null | sed -n '1,10p' || diag_warn "systemctl unavailable"
  bold "== disk =="
  df -h / /opt /var 2>/dev/null || df -h /
  bold "== docker =="
  if docker info >/dev/null 2>&1; then
    diag_ok "docker daemon reachable"
    docker ps --filter health=unhealthy --format '  unhealthy: {{.Names}}' 2>/dev/null || true
    docker ps --filter status=exited --format '  stopped: {{.Names}}' 2>/dev/null | sed -n '1,10p' || true
  else diag_fail "docker daemon unreachable"; fi
  bold "== tailscale =="
  tailscale status --self >/dev/null 2>&1 && diag_ok "tailscale up" || diag_warn "tailscale not up; run sudo homeos config net tailscale-up"
  bold "== caddy =="
  have_cmd caddy && caddy validate --config /etc/caddy/Caddyfile >/dev/null 2>&1 && diag_ok "caddy config valid" || diag_warn "caddy validation unavailable/failed"
  bold "== backup =="
  if [ -r "$BACKUP_ENV" ]; then
    # shellcheck disable=SC1090
    source "$BACKUP_ENV"
    [ -n "${RESTIC_REPOSITORY:-}" ] && diag_ok "backup target configured: $RESTIC_REPOSITORY" || diag_warn "backup target unset"
  elif [ -f "$BACKUP_ENV" ]; then
    diag_warn "backup config exists but is not readable; run sudo homeos diag or sudo homeos config backup target show"
  else diag_warn "backup.env missing"; fi
  [ -f /var/log/homeos-backup.log ] && tail -n 5 /var/log/homeos-backup.log || true
  bold "== suggestions =="
  echo "  logs: homeos log firstboot|backup|docker|stack:<name>"
  echo "  strict smoke test: homeos doctor"
  [ "$fails" -eq 0 ] || exit 1
}

# ---------- dispatch ----------
main() {
  HOMEOS_ORIGINAL_ARGV_JSON="$(json_argv "$@")"
  export HOMEOS_ORIGINAL_ARGV_JSON
  local top="${1:-}"; shift || true
  case "$top" in
    status)  cmd_status "$@" ;;
    doctor)  cmd_doctor "$@" ;;
    diag)    cmd_diag "$@" ;;
    log)     cmd_log "$@" ;;
    init)    cmd_init "$@" ;;
    upgrade) cmd_upgrade "$@" ;;
    secure)  cmd_secure "$@" ;;
    install) cmd_install "$@" ;;
    audit)   cmd_audit "$@" ;;
    config)
      local section="${1:-}"; shift || true
      case "$section" in
        rerun-bootstrap) cmd_rerun_bootstrap "$@" ;;
        secrets)         cmd_secrets "$@" ;;
        nas)             cmd_nas "$@" ;;
        stack)           cmd_stack "$@" ;;
        net)             cmd_net "$@" ;;
        backup)          cmd_backup "$@" ;;
        portal)          cmd_portal "$@" ;;
        cosmos)          cmd_cosmos "$@" ;;
        gate)            cmd_gate "$@" ;;
        *) usage; exit 2 ;;
      esac
      ;;
    ""|-h|--help|help) usage ;;
    *) usage; exit 2 ;;
  esac
}
main "$@"
