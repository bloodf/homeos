#!/usr/bin/env bash
# HomeOS day-2 ops dispatcher.
# Usage: homeos <command> [args...]
set -euo pipefail

ADMIN_USER="${SUDO_USER:-admin}"
ADMIN_HOME="$(getent passwd "$ADMIN_USER" | cut -d: -f6)"
HOMEOS_ROOT="/opt/homeos"
SECRETS="$ADMIN_HOME/.config/homeos/secrets.env"
NAS_VARS="$HOMEOS_ROOT/bootstrap/vars/nas_disks.yml"
BACKUP_ENV="/etc/homeos/backup.env"
AUDIT_LOG="/var/log/homeos-audit.jsonl"
INSTALLED_DIR="/var/lib/homeos/installed.d"
GATE_PROVIDER_FILE="/var/lib/homeos/ai-gate-provider"   # claude|openai|openrouter|ollama|none
PENDING_DIR="/var/lib/homeos/pending"

bold() { printf '\033[1m%s\033[0m\n' "$*"; }
warn() { printf '\033[1;33mwarn:\033[0m %s\n' "$*" >&2; }
err()  { printf '\033[1;31merror:\033[0m %s\n' "$*" >&2; exit 1; }
need_root() { [ "$(id -u)" -eq 0 ] || err "run with sudo"; }

# ---------- audit log ----------
audit_log() {
  # audit_log <command> <verdict> <user_choice> <diff_hash>
  local cmd="$1" verdict="${2:-n/a}" choice="${3:-n/a}" hash="${4:-n/a}"
  mkdir -p "$(dirname "$AUDIT_LOG")"
  python3 -c "
import json, sys, time, os
entry = {
  'ts': time.strftime('%Y-%m-%dT%H:%M:%S%z'),
  'cmd': '$cmd',
  'user': os.environ.get('SUDO_USER') or os.environ.get('USER') or 'unknown',
  'verdict': '$verdict',
  'choice': '$choice',
  'diff_hash': '$hash',
}
print(json.dumps(entry))
" >> "$AUDIT_LOG" 2>/dev/null || true
}

# ---------- AI review gate ----------
ai_provider() {
  [ -f "$GATE_PROVIDER_FILE" ] && cat "$GATE_PROVIDER_FILE" || echo "none"
}

ai_review() {
  # ai_review <intent_label> <diff_text> -> echo verdict to stdout, return 0 always
  local intent="$1" diff="$2"
  local provider; provider="$(ai_provider)"
  [ "$provider" = "none" ] && { echo "skip"; return 0; }
  # Source secrets so keys reach the CLI
  [ -f "$SECRETS" ] && set -a && . "$SECRETS" && set +a
  local prompt="You review HomeOS config changes. Reply with one line: APPROVE | WARN: <reason> | REJECT: <reason>. Intent: $intent. Diff:
$diff"
  case "$provider" in
    claude)     sudo -u "$ADMIN_USER" -E claude -p "$prompt" 2>/dev/null | head -3 || echo "skip" ;;
    openai)     sudo -u "$ADMIN_USER" -E codex -p "$prompt" 2>/dev/null | head -3 || echo "skip" ;;
    openrouter) sudo -u "$ADMIN_USER" -E opencode run -m "openrouter/anthropic/claude-3.5-sonnet" "$prompt" 2>/dev/null | head -3 || echo "skip" ;;
    ollama)     curl -fsS http://127.0.0.1:11434/api/generate -d "{\"model\":\"qwen3:7b\",\"prompt\":$(python3 -c 'import json,sys;print(json.dumps(sys.argv[1]))' "$prompt"),\"stream\":false}" 2>/dev/null | python3 -c 'import json,sys;print(json.load(sys.stdin).get("response","skip").strip())' || echo "skip" ;;
    *)          echo "skip" ;;
  esac
}

gate() {
  # gate <intent_label> <diff_text> <command...>
  # Runs AI review (warn-only) + audit log around the command.
  local intent="$1" diff="$2"; shift 2
  local hash; hash="$(printf '%s' "$diff" | sha256sum | head -c 12)"
  local verdict="skip"
  if [ "${HOMEOS_NO_REVIEW:-}" = "1" ]; then
    warn "AI review bypassed (HOMEOS_NO_REVIEW=1)"
    verdict="bypass"
  elif [ "$(ai_provider)" != "none" ]; then
    bold "== AI review ($intent) =="
    verdict="$(ai_review "$intent" "$diff" | tr -d '\n' | head -c 400)"
    case "$verdict" in
      APPROVE*)  printf '\033[32m%s\033[0m\n' "$verdict" ;;
      WARN*)     printf '\033[33m%s\033[0m\n' "$verdict" ;;
      REJECT*)   printf '\033[31m%s\033[0m\n' "$verdict" ;;
      *)         printf '%s\n' "$verdict" ;;
    esac
  fi
  if [ -t 0 ] && [ "${HOMEOS_AUTO_APPLY:-}" != "1" ]; then
    read -r -p "apply? [y/N] " ans
    if [[ ! "$ans" =~ ^[Yy]$ ]]; then
      audit_log "$intent" "$verdict" "abort" "$hash"
      err "aborted"
    fi
  fi
  audit_log "$intent" "$verdict" "apply" "$hash"
  "$@"
}

usage() {
  cat <<'EOF'
homeos — HomeOS day-2 ops

  homeos status                              show services, disks, containers, GPU
  homeos doctor                              run smoke tests
  homeos secure                              lock down SSH (key-only) + lock admin password
  homeos config rerun-bootstrap              re-run Ansible playbook
  homeos config secrets list
  homeos config secrets set KEY=VAL          (or KEY VAL)
  homeos config secrets get KEY
  homeos config nas list
  homeos config nas add /dev/sdX[N]          mount + share USB drive
  homeos config nas remove LABEL
  homeos config stack up    NAME
  homeos config stack down  NAME
  homeos config stack update NAME            pull + recreate
  homeos config stack logs  NAME
  homeos config net tailscale-up [--auth-key KEY]
  homeos config net caddy-reload
  homeos config backup target set /srv/nas/<label>
  homeos config backup run                   trigger backup now
  homeos config portal on|off|status         toggle web portal (Homepage + Open WebUI + ttyd)
  homeos config cosmos on|off|status         toggle Cosmos Cloud (alt portal: auth + container UI)
  homeos config gate set <provider>          AI review provider: claude|openai|openrouter|ollama|none
  homeos config gate show
  homeos install <feature> [--reconfigure]   opt-in installer (see: homeos install --list)
  homeos install --list
  homeos audit tail [-n N]                   tail audit log
  homeos audit search <pattern>
  homeos audit cosmos-events [-n N]          tail Cosmos-origin bypass events
EOF
}

# ---------- status ----------
cmd_status() {
  bold "== services =="
  systemctl is-active docker tailscaled cockpit.socket casaos caddy smbd nfs-kernel-server 2>/dev/null | paste <(echo -e "docker\ntailscaled\ncockpit\ncasaos\ncaddy\nsmbd\nnfs") - || true
  bold "== disks =="
  lsblk -o NAME,SIZE,TYPE,MOUNTPOINT,FSTYPE,UUID
  bold "== containers =="
  docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || echo "docker not running"
  bold "== GPU =="
  vainfo 2>&1 | grep -E 'Driver version|VAProfile' | head -10 || true
  bold "== tailscale =="
  tailscale status --self 2>/dev/null | head -5 || echo "tailscale not up"
}

# ---------- doctor ----------
cmd_doctor() {
  fails=0
  check() {
    local label="$1"; shift
    if "$@" >/dev/null 2>&1; then printf "  \033[32m✓\033[0m %s\n" "$label"
    else printf "  \033[31m✗\033[0m %s\n" "$label"; fails=$((fails+1)); fi
  }
  bold "== runtime =="
  check "node v24"        bash -c 'node -v | grep -q "^v24\\."'
  check "docker"          docker --version
  check "docker compose"  docker compose version
  check "brew"            sudo -u "$ADMIN_USER" /home/linuxbrew/.linuxbrew/bin/brew --version
  bold "== AI CLIs =="
  for cli in claude codex gemini cursor-agent opencode kimi; do
    check "$cli"          sudo -u "$ADMIN_USER" bash -lc "command -v $cli"
  done
  bold "== services =="
  check "GPU iHD"         bash -c 'vainfo 2>/dev/null | grep -q iHD'
  check "cockpit"         systemctl is-active cockpit.socket
  check "casaos"          systemctl is-active casaos
  check "tailscaled"      systemctl is-active tailscaled
  bold "== HTTP =="
  check "HA :8123"        curl -fsS http://localhost:8123 -o /dev/null
  check "Jellyfin :8096"  curl -fsS http://localhost:8096 -o /dev/null
  check "CasaOS :81"      curl -fsS http://localhost:81 -o /dev/null
  check "Cockpit :9090"   curl -fsSk https://localhost:9090 -o /dev/null
  bold "== tools =="
  for d in hindsight code-review-graph portless claude-context utoo hermes-agent OpenViking oh-my-opencode oh-my-claudecode claude-mem; do
    check "/opt/tools/$d" test -d "/opt/tools/$d"
  done
  echo
  if [ "$fails" -eq 0 ]; then bold "ALL OK"; else bold "$fails check(s) failed"; exit 1; fi
}

# ---------- config rerun-bootstrap ----------
cmd_rerun_bootstrap() {
  need_root
  local diff="ansible-playbook full-bootstrap re-run, args: $*"
  gate "rerun-bootstrap" "$diff" \
    ansible-playbook -i localhost, -c local "$HOMEOS_ROOT/bootstrap/install.yml" "$@"
}

# ---------- secrets ----------
secrets_path() {
  local home; home="$(getent passwd "$ADMIN_USER" | cut -d: -f6)"
  echo "$home/.config/homeos/secrets.env"
}

cmd_secrets() {
  local sub="${1:-}"; shift || true
  local f; f="$(secrets_path)"
  [ -f "$f" ] || install -m 600 -o "$ADMIN_USER" -g "$ADMIN_USER" /dev/null "$f"
  case "$sub" in
    list) sed 's/=.*/=***/' "$f" ;;
    get)  local k="${1:?KEY required}"; grep -E "^$k=" "$f" | head -1 | cut -d= -f2- ;;
    set)
      local arg="${1:?KEY=VAL or KEY VAL required}"
      local k v
      if [[ "$arg" == *=* ]]; then k="${arg%%=*}"; v="${arg#*=}"; else k="$arg"; v="${2:?VAL required}"; fi
      gate "secrets:set:$k" "set secret key $k (value redacted, length=${#v})" true
      sed -i "/^${k}=/d" "$f"
      echo "${k}=${v}" >> "$f"
      chmod 600 "$f"; chown "$ADMIN_USER:$ADMIN_USER" "$f"
      echo "set $k"
      ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- nas ----------
cmd_nas() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    list)
      sudo -u "$ADMIN_USER" cat "$NAS_VARS" 2>/dev/null || true
      lsblk -o NAME,LABEL,SIZE,FSTYPE,UUID,MOUNTPOINT
      ;;
    add)
      need_root
      local dev="${1:?device required, e.g. /dev/sdc1}"
      local uuid fstype label
      uuid="$(blkid -s UUID -o value "$dev")"
      fstype="$(blkid -s TYPE -o value "$dev")"
      label="$(blkid -s LABEL -o value "$dev" || true)"
      [ -n "$label" ] || label="nas-$(echo "$uuid" | tr -d - | head -c8)"
      [ -n "$uuid" ] || err "no UUID for $dev"
      gate "nas:add" "device=$dev uuid=$uuid label=$label fstype=$fstype" true
      python3 - <<PY
import yaml, pathlib
p = pathlib.Path("$NAS_VARS")
data = yaml.safe_load(p.read_text()) or {}
disks = data.setdefault("nas_disks", []) or []
if not any(d.get("uuid")=="$uuid" for d in disks):
    disks.append({"uuid":"$uuid","label":"$label","fstype":"$fstype"})
data["nas_disks"]=disks
p.write_text(yaml.safe_dump(data, sort_keys=False))
PY
      ansible-playbook -i localhost, -c local "$HOMEOS_ROOT/bootstrap/install.yml" --tags nas || \
      ansible-playbook -i localhost, -c local "$HOMEOS_ROOT/bootstrap/install.yml"
      echo "share: //$(hostname)/$label"
      ;;
    remove)
      need_root
      local label="${1:?label required}"
      gate "nas:remove" "label=$label (drops mount + share)" true
      python3 - <<PY
import yaml, pathlib
p = pathlib.Path("$NAS_VARS")
data = yaml.safe_load(p.read_text()) or {}
data["nas_disks"] = [d for d in (data.get("nas_disks") or []) if d.get("label")!="$label"]
p.write_text(yaml.safe_dump(data, sort_keys=False))
PY
      systemctl disable --now "srv-nas-${label}.mount" 2>/dev/null || true
      ansible-playbook -i localhost, -c local "$HOMEOS_ROOT/bootstrap/install.yml" || true
      ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- stack ----------
cmd_stack() {
  local sub="${1:?up|down|update|logs}"; local name="${2:?stack name}"
  local dir="/opt/stacks/$name"
  [ -d "$dir" ] || err "no stack at $dir"
  case "$sub" in
    up)     gate "stack:up:$name"     "compose up at $dir"            sh -c "cd '$dir' && docker compose up -d" ;;
    down)   gate "stack:down:$name"   "compose down at $dir"          sh -c "cd '$dir' && docker compose down" ;;
    update) gate "stack:update:$name" "compose pull+recreate at $dir" sh -c "cd '$dir' && docker compose pull && docker compose up -d" ;;
    logs)   (cd "$dir" && docker compose logs -f) ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- net ----------
cmd_net() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    tailscale-up)
      need_root
      local key=""
      while [ $# -gt 0 ]; do
        case "$1" in --auth-key) key="$2"; shift 2 ;; *) shift ;; esac
      done
      if [ -n "$key" ]; then
        tailscale up --ssh --accept-routes --auth-key "$key"
      else
        tailscale up --ssh --accept-routes
      fi
      tailscale status
      local fqdn; fqdn="$(tailscale status --json 2>/dev/null | python3 -c 'import sys,json;d=json.load(sys.stdin);print(d["Self"]["DNSName"].rstrip(".") if d.get("Self") else "")' 2>/dev/null || true)"
      [ -n "$fqdn" ] && echo "HOMEOS_TAILNET=$fqdn" > /etc/default/caddy
      systemctl reload caddy 2>/dev/null || true
      ;;
    caddy-reload)
      need_root
      systemctl reload caddy
      ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- backup ----------
cmd_backup() {
  local sub="${1:?target|run}"; shift || true
  case "$sub" in
    target)
      local action="${1:?set}"; local path="${2:?path required}"
      need_root
      [ "$action" = "set" ] || err "only 'set' supported"
      sed -i "s|^RESTIC_REPOSITORY=.*|RESTIC_REPOSITORY=$path|" "$BACKUP_ENV"
      mkdir -p "$path"
      echo "backup target: $path"
      ;;
    run)
      need_root
      /usr/local/sbin/homeos-backup
      ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- portal ----------
cmd_portal() {
  local sub="${1:-status}"
  local flag="/var/lib/homeos/portal.enabled"
  local dir="/opt/stacks/portal"
  case "$sub" in
    on)
      need_root
      [ -d "$dir" ] || err "portal stack not installed at $dir — run rerun-bootstrap"
      mkdir -p "$(dirname "$flag")"
      gate "portal:on" "enable portal flag + docker compose up at $dir" true
      touch "$flag"
      (cd "$dir" && docker compose up -d)
      bold "portal up. Tailscale URLs:"
      echo "  https://portal.<tailnet>.ts.net   dashboard"
      echo "  https://chat.<tailnet>.ts.net     Open WebUI"
      echo "  https://stacks.<tailnet>.ts.net   Dockge"
      echo "  https://files.<tailnet>.ts.net    Filebrowser"
      ;;
    off)
      need_root
      rm -f "$flag"
      [ -d "$dir" ] && (cd "$dir" && docker compose down) || true
      bold "portal down."
      ;;
    status)
      if [ -f "$flag" ]; then echo "flag: enabled"; else echo "flag: disabled"; fi
      docker ps --filter "label=com.docker.compose.project=portal" \
        --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || true
      ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- cosmos ----------
cmd_cosmos() {
  local sub="${1:-status}"
  local flag="/var/lib/homeos/cosmos.enabled"
  local dir="/opt/stacks/cosmos"
  local audit_unit="homeos-cosmos-audit.service"
  case "$sub" in
    on)
      need_root
      [ -d "$dir" ] || err "cosmos stack not installed at $dir — run rerun-bootstrap"
      gate "cosmos:on" "enable cosmos flag + docker compose up at $dir" \
        sh -c "mkdir -p '$(dirname "$flag")' && touch '$flag' && cd '$dir' && docker compose up -d"
      systemctl enable --now "$audit_unit" 2>/dev/null || warn "$audit_unit not installed yet — run rerun-bootstrap to enable Cosmos audit mirroring"
      bold "cosmos up. URL:"
      echo "  https://cosmos.<tailnet>.ts.net"
      echo "  first-run setup runs in browser; create admin account immediately."
      ;;
    off)
      need_root
      gate "cosmos:off" "disable cosmos flag + docker compose down at $dir" \
        sh -c "rm -f '$flag'; [ -d '$dir' ] && (cd '$dir' && docker compose down) || true"
      systemctl disable --now "$audit_unit" 2>/dev/null || true
      bold "cosmos down."
      ;;
    status)
      if [ -f "$flag" ]; then echo "flag: enabled"; else echo "flag: disabled"; fi
      docker ps --filter "name=cosmos" \
        --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || true
      systemctl --no-pager --lines=0 status "$audit_unit" 2>/dev/null | sed -n '1,3p' || true
      ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- gate ----------
cmd_gate() {
  local sub="${1:?set|show}"; shift || true
  case "$sub" in
    set)
      need_root
      local p="${1:?provider required: claude|openai|openrouter|ollama|none}"
      case "$p" in claude|openai|openrouter|ollama|none) ;; *) err "unknown provider $p" ;; esac
      mkdir -p /var/lib/homeos
      echo "$p" > "$GATE_PROVIDER_FILE"
      bold "AI review gate provider: $p"
      ;;
    show)
      echo "provider: $(ai_provider)"
      ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- audit ----------
cmd_audit() {
  local sub="${1:-tail}"; shift || true
  case "$sub" in
    tail)
      local n=20
      [ "${1:-}" = "-n" ] && n="$2"
      [ -f "$AUDIT_LOG" ] || { echo "no audit entries yet"; return 0; }
      tail -n "$n" "$AUDIT_LOG" | python3 -c '
import sys, json
for line in sys.stdin:
  try:
    e = json.loads(line)
    print(f"{e[\"ts\"]}  {e[\"user\"]:>10}  {e[\"cmd\"]:<28}  verdict={e[\"verdict\"][:40]:<40}  choice={e[\"choice\"]}")
  except Exception:
    print(line.rstrip())
'
      ;;
    search)
      local pat="${1:?pattern required}"
      [ -f "$AUDIT_LOG" ] || { echo "no audit entries yet"; return 0; }
      grep -i -- "$pat" "$AUDIT_LOG" || true
      ;;
    cosmos-events)
      local n=20
      [ "${1:-}" = "-n" ] && n="${2:?count required}"
      [ -f "$AUDIT_LOG" ] || { echo "no audit entries yet"; return 0; }
      python3 - "$AUDIT_LOG" "$n" <<'PY'
import json, sys
path, count = sys.argv[1], int(sys.argv[2])
entries = []
with open(path, encoding="utf-8") as fh:
    for line in fh:
        try:
            entry = json.loads(line)
        except Exception:
            continue
        if str(entry.get("cmd", "")).startswith("cosmos:"):
            entries.append(entry)
for e in entries[-count:]:
    print(f"{e.get('ts','')}  {e.get('cmd',''):<28}  verdict={e.get('verdict','')}  hash={e.get('diff_hash','')}  {e.get('summary','')}")
PY
      ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- install ----------
INSTALLERS=(ollama mcp-hub media-stack offsite-backup ai-keys monitoring image-gen voice)

install_flag() { echo "$INSTALLED_DIR/$1.installed"; }
is_installed() { [ -f "$(install_flag "$1")" ]; }
mark_installed() { mkdir -p "$INSTALLED_DIR"; touch "$(install_flag "$1")"; }

cmd_install() {
  local feat="${1:-}"; shift || true
  if [ "$feat" = "--list" ] || [ -z "$feat" ]; then
    bold "available installers:"
    for f in "${INSTALLERS[@]}"; do
      if is_installed "$f"; then echo "  [x] $f"; else echo "  [ ] $f"; fi
    done
    echo
    echo "usage: sudo homeos install <feature> [--reconfigure]"
    return 0
  fi
  local reconfigure=0
  [ "${1:-}" = "--reconfigure" ] && reconfigure=1
  need_root
  if is_installed "$feat" && [ "$reconfigure" -eq 0 ]; then
    bold "$feat already installed (use --reconfigure to redo)"
    return 0
  fi
  local script="/opt/homeos/bootstrap/installers/${feat}.sh"
  [ -x "$script" ] || err "no installer at $script"
  gate "install:$feat" "feature=$feat reconfigure=$reconfigure" \
    bash "$script" $([ "$reconfigure" -eq 1 ] && echo "--reconfigure")
  mark_installed "$feat"
  bold "installed: $feat"
}

# ---------- secure ----------
cmd_secure() {
  need_root
  local ak="$ADMIN_HOME/.ssh/authorized_keys"
  if [ ! -s "$ak" ]; then
    err "no $ak — upload your pubkey first (scp ~/.ssh/id_ed25519.pub admin@host:.ssh/authorized_keys)"
  fi
  if ! grep -qE '^(ssh-(rsa|ed25519|dss)|ecdsa-sha2)' "$ak"; then
    err "$ak has no recognizable public key line — refusing to lock"
  fi
  local conf=/etc/ssh/sshd_config.d/99-homeos.conf
  sed -i 's/^PasswordAuthentication .*/PasswordAuthentication no/' "$conf"
  if ! grep -q '^PasswordAuthentication no' "$conf"; then
    echo "PasswordAuthentication no" >> "$conf"
  fi
  sshd -t || err "sshd config invalid — aborting before restart"
  systemctl restart ssh
  passwd -l "$ADMIN_USER"
  bold "secured: password auth off, $ADMIN_USER password locked"
  echo "to undo: sudo passwd -u $ADMIN_USER && edit $conf"
}

# ---------- dispatch ----------
main() {
  local top="${1:-}"; shift || true
  case "$top" in
    status)  cmd_status "$@" ;;
    doctor)  cmd_doctor "$@" ;;
    secure)  cmd_secure "$@" ;;
    install) cmd_install "$@" ;;
    audit)   cmd_audit "$@" ;;
    config)
      local section="${1:-}"; shift || true
      case "$section" in
        rerun-bootstrap) cmd_rerun_bootstrap "$@" ;;
        secrets)         cmd_secrets "$@" ;;
        nas)             cmd_nas "$@" ;;
        stack)           cmd_stack "$@" ;;
        net)             cmd_net "$@" ;;
        backup)          cmd_backup "$@" ;;
        portal)          cmd_portal "$@" ;;
        cosmos)          cmd_cosmos "$@" ;;
        gate)            cmd_gate "$@" ;;
        *) usage; exit 2 ;;
      esac
      ;;
    ""|-h|--help|help) usage ;;
    *) usage; exit 2 ;;
  esac
}
main "$@"
