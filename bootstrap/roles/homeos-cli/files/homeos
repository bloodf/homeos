#!/usr/bin/env bash
# HomeOS day-2 ops dispatcher.
# Usage: homeos <command> [args...]
set -euo pipefail

ADMIN_USER="${HOMEOS_ADMIN_USER:-${SUDO_USER:-admin}}"
ADMIN_GROUP="${HOMEOS_ADMIN_GROUP:-$ADMIN_USER}"
ADMIN_HOME="${HOMEOS_ADMIN_HOME:-$(getent passwd "$ADMIN_USER" 2>/dev/null | cut -d: -f6 || true)}"
[ -n "$ADMIN_HOME" ] || ADMIN_HOME="${HOME:-/home/$ADMIN_USER}"
HOMEOS_ROOT="${HOMEOS_ROOT:-/opt/homeos}"
SECRETS="$ADMIN_HOME/.config/homeos/secrets.env"
NAS_VARS="${HOMEOS_NAS_VARS:-$HOMEOS_ROOT/bootstrap/vars/nas_disks.yml}"
BACKUP_ENV="${HOMEOS_BACKUP_ENV:-/etc/homeos/backup.env}"
AUDIT_LOG="${HOMEOS_AUDIT_LOG:-/var/log/homeos-audit.jsonl}"
AUDIT_REPLAY_DIR="${HOMEOS_AUDIT_REPLAY_DIR:-/var/lib/homeos/audit-replay}"
INSTALLED_DIR="${HOMEOS_INSTALLED_DIR:-/var/lib/homeos/installed.d}"
GATE_PROVIDER_FILE="${HOMEOS_GATE_PROVIDER_FILE:-/var/lib/homeos/ai-gate-provider}"   # claude|openai|openrouter|ollama|none
PENDING_DIR="${HOMEOS_PENDING_DIR:-/var/lib/homeos/pending}"
BOOTSTRAPPED_MARKER="${HOMEOS_BOOTSTRAPPED_MARKER:-/var/lib/homeos/bootstrapped}"
BOOTSTRAP_FAILED_MARKER="${HOMEOS_BOOTSTRAP_FAILED_MARKER:-/var/lib/homeos/bootstrap-failed}"
STACK_DIGEST_DIR="${HOMEOS_STACK_DIGEST_DIR:-/var/lib/homeos/stack-digests}"

bold() { printf '\033[1m%s\033[0m\n' "$*"; }
warn() { printf '\033[1;33mwarn:\033[0m %s\n' "$*" >&2; }
err()  { printf '\033[1;31merror:\033[0m %s\n' "$*" >&2; exit 1; }
need_root() { [ "$(id -u)" -eq 0 ] || err "run with sudo"; }
have_cmd() { command -v "$1" >/dev/null 2>&1; }
require_tty_for_interactive() { [ -t 0 ] || err "$1 requires a TTY; pass explicit flags or use --dry-run"; }
confirm_prompt() {
  local prompt="$1" default="${2:-n}" ans
  if [ "${HOMEOS_ASSUME_YES:-}" = "1" ]; then return 0; fi
  read -r -p "$prompt ${default:+[$default] }" ans
  ans="${ans:-$default}"
  [[ "$ans" =~ ^[Yy]$ ]]
}
prompt_value() {
  local prompt="$1" value
  read -r -p "$prompt: " value
  [ -n "$value" ] || err "value required for $prompt"
  printf '%s\n' "$value"
}
prompt_secret() {
  local prompt="$1" value
  read -r -s -p "$prompt: " value; echo >&2
  [ -n "$value" ] || err "secret required for $prompt"
  printf '%s\n' "$value"
}
run_step() {
  local label="$1"; shift
  bold "== $label =="
  "$@"
}

hash12() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum | head -c 12
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 | head -c 12
  else
    err "sha256sum or shasum required"
  fi
}

# ---------- audit log ----------
json_argv() {
  python3 - "$@" <<'PY'
import json, sys
args = sys.argv[1:]
secret_flags = {"--auth-key", "--password", "--token", "--secret", "--key"}
out = []
redact_next = False
for arg in args:
    if redact_next:
        out.append("<redacted>")
        redact_next = False
        continue
    if arg in secret_flags:
        out.append(arg)
        redact_next = True
        continue
    if any(arg.startswith(flag + "=") for flag in secret_flags):
        out.append(arg.split("=", 1)[0] + "=<redacted>")
        continue
    out.append(arg)
print(json.dumps(out))
PY
}

audit_log() {
  # audit_log <command> <verdict> <user_choice> <diff_hash> [orig_intent] [diff_text]
  local cmd="$1" verdict="${2:-n/a}" choice="${3:-n/a}" hash="${4:-n/a}"
  local orig_intent="${5:-$cmd}" diff_text="${6:-}"
  local sidecar_id=""
  mkdir -p "$(dirname "$AUDIT_LOG")"
  if [ -n "$diff_text" ] && [ "$hash" != "n/a" ]; then
    mkdir -p "$AUDIT_REPLAY_DIR"
    chmod 0700 "$AUDIT_REPLAY_DIR"
    sidecar_id="$(python3 - "$AUDIT_REPLAY_DIR" "$hash" "$cmd" "$orig_intent" "$choice" "$diff_text" "${HOMEOS_ORIGINAL_ARGV_JSON:-[]}" <<'PY'
import json, os, pathlib, sys, time
replay_dir = pathlib.Path(sys.argv[1])
diff_hash, cmd, orig_intent, choice, diff_text, argv_json = sys.argv[2:8]
try:
    argv = json.loads(argv_json)
    if not isinstance(argv, list) or not all(isinstance(x, str) for x in argv):
        argv = []
except Exception:
    argv = []
base = f"{diff_hash}.json"
path = replay_dir / base
if path.exists():
    stamp = time.strftime("%Y%m%dT%H%M%S")
    ns = time.time_ns() if hasattr(time, "time_ns") else int(time.time() * 1000000000)
    base = f"{diff_hash}-{stamp}-{os.getpid()}-{ns}.json"
    path = replay_dir / base
payload = {
    "schema": "homeos.audit-replay.v1",
    "ts": time.strftime('%Y-%m-%dT%H:%M:%S%z'),
    "user": os.environ.get('SUDO_USER') or os.environ.get('USER') or 'unknown',
    "cmd": cmd,
    "orig_intent": orig_intent,
    "choice": choice,
    "diff_hash": diff_hash,
    "argv": argv,
    "replay_env": {
        "HOMEOS_ADMIN_USER": os.environ.get("HOMEOS_ADMIN_USER") or os.environ.get("SUDO_USER") or "admin",
        "HOMEOS_ADMIN_GROUP": os.environ.get("HOMEOS_ADMIN_GROUP") or os.environ.get("HOMEOS_ADMIN_USER") or os.environ.get("SUDO_USER") or "admin",
        "HOMEOS_ADMIN_HOME": os.environ.get("HOMEOS_ADMIN_HOME", ""),
        "HOMEOS_ROOT": os.environ.get("HOMEOS_ROOT", "/opt/homeos"),
    },
    "diff_text": diff_text,
    "redaction": {
        "public_jsonl_omits": ["argv", "diff_text", "replay_env"],
        "policy": "secret-bearing argv and replay material are stored only in this root-only sidecar; public JSONL keeps command label, verdict, choice, hash, and sidecar id only",
    },
}
with open(path, "x", encoding="utf-8") as fh:
    json.dump(payload, fh, sort_keys=True)
    fh.write("\n")
os.chmod(path, 0o600)
print(base)
PY
)"
  fi
  python3 - "$cmd" "$verdict" "$choice" "$hash" "$sidecar_id" <<'PY' >> "$AUDIT_LOG"
import json, os, sys, time
cmd, verdict, choice, diff_hash, sidecar_id = sys.argv[1:6]
entry = {
  'ts': time.strftime('%Y-%m-%dT%H:%M:%S%z'),
  'cmd': cmd,
  'user': os.environ.get('SUDO_USER') or os.environ.get('USER') or 'unknown',
  'verdict': verdict,
  'choice': choice,
  'diff_hash': diff_hash,
}
if sidecar_id:
  entry['sidecar_id'] = sidecar_id
print(json.dumps(entry, sort_keys=True))
PY
}

# ---------- AI review gate ----------
ai_provider() {
  [ -f "$GATE_PROVIDER_FILE" ] && cat "$GATE_PROVIDER_FILE" || echo "none"
}

ai_review() {
  # ai_review <intent_label> <diff_text> -> echo verdict to stdout, return 0 always
  local intent="$1" diff="$2"
  local provider; provider="$(ai_provider)"
  [ "$provider" = "none" ] && { echo "skip"; return 0; }
  # Source secrets so keys reach the CLI
  [ -f "$SECRETS" ] && set -a && . "$SECRETS" && set +a
  local prompt="You review HomeOS config changes. Reply with one line: APPROVE | WARN: <reason> | REJECT: <reason>. Intent: $intent. Diff:
$diff"
  case "$provider" in
    claude)     sudo -u "$ADMIN_USER" -E claude -p "$prompt" 2>/dev/null | head -3 || echo "skip" ;;
    openai)     sudo -u "$ADMIN_USER" -E codex -p "$prompt" 2>/dev/null | head -3 || echo "skip" ;;
    openrouter) sudo -u "$ADMIN_USER" -E opencode run -m "openrouter/anthropic/claude-3.5-sonnet" "$prompt" 2>/dev/null | head -3 || echo "skip" ;;
    ollama)     curl -fsS http://127.0.0.1:11434/api/generate -d "{\"model\":\"qwen3:7b\",\"prompt\":$(python3 -c 'import json,sys;print(json.dumps(sys.argv[1]))' "$prompt"),\"stream\":false}" 2>/dev/null | python3 -c 'import json,sys;print(json.load(sys.stdin).get("response","skip").strip())' || echo "skip" ;;
    *)          echo "skip" ;;
  esac
}

gate() {
  # gate <intent_label> <diff_text> <command...>
  # Runs AI review (warn-only) + audit log around the command.
  need_root
  local intent="$1" diff="$2"; shift 2
  local hash; hash="$(printf '%s' "$diff" | hash12)"
  local verdict="skip"
  if [ "${HOMEOS_NO_REVIEW:-}" = "1" ]; then
    warn "AI review bypassed (HOMEOS_NO_REVIEW=1)"
    verdict="bypass"
  elif [ "$(ai_provider)" != "none" ]; then
    bold "== AI review ($intent) =="
    verdict="$(ai_review "$intent" "$diff" | tr -d '\n' | head -c 400)"
    case "$verdict" in
      APPROVE*)  printf '\033[32m%s\033[0m\n' "$verdict" ;;
      WARN*)     printf '\033[33m%s\033[0m\n' "$verdict" ;;
      REJECT*)   printf '\033[31m%s\033[0m\n' "$verdict" ;;
      *)         printf '%s\n' "$verdict" ;;
    esac
  fi
  if [ -t 0 ] && [ "${HOMEOS_AUTO_APPLY:-}" != "1" ]; then
    read -r -p "apply? [y/N] " ans
    if [[ ! "$ans" =~ ^[Yy]$ ]]; then
      audit_log "${HOMEOS_REPLAY_AUDIT_CMD:-$intent}" "$verdict" "abort" "$hash" "$intent" "$diff" || err "audit logging failed; aborting without applying"
      err "aborted"
    fi
  fi
  audit_log "${HOMEOS_REPLAY_AUDIT_CMD:-$intent}" "$verdict" "apply" "$hash" "$intent" "$diff" || err "audit logging failed; refusing to apply"
  "$@"
}

