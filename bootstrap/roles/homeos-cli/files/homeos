stack_update_impl() {
  local name="$1" dir="$2" snap
  preflight_stack_update_space "$name" "$dir"
  snap="$(stack_record_digests "$name" "$dir")"
  echo "recorded pre-update image snapshot: $snap"
  (cd "$dir" && docker compose pull && docker compose up -d)
}

stack_rollback_impl() {
  local name="$1" dir="$2" snapshot="${3:-}" compose backup stamp snap_real root_real
  validate_stack_name "$name"
  [ -n "$snapshot" ] || snapshot="$(stack_latest_snapshot "$name")"
  [ -n "$snapshot" ] || err "no digest snapshots for $name"
  root_real="$(mkdir -p "$STACK_DIGEST_DIR" && cd "$STACK_DIGEST_DIR" && pwd -P)"
  snap_real="$(python3 - "$snapshot" <<'PY'
import pathlib, sys
print(pathlib.Path(sys.argv[1]).resolve(strict=False))
PY
)"
  case "$snap_real" in "$root_real"/"$name"-*.json) ;; *) err "snapshot must be a $name snapshot under $STACK_DIGEST_DIR" ;; esac
  [ ! -L "$snapshot" ] || err "snapshot symlinks are not allowed"
  compose="$dir/docker-compose.yml"
  [ -f "$compose" ] || err "missing compose file: $compose"
  stamp="$(date -u +%Y%m%dT%H%M%SZ)"
  backup="${compose}.bak.${stamp}"
  cp -a "$compose" "$backup"
  python3 - "$snapshot" "$compose" "$name" <<'PY'
import json, pathlib, sys, yaml
snap_path, compose_path = map(pathlib.Path, sys.argv[1:3])
expected_stack = sys.argv[3]
snap = json.loads(snap_path.read_text(encoding='utf-8'))
if snap.get('stack') != expected_stack:
    raise SystemExit(f'snapshot stack mismatch: expected {expected_stack}, got {snap.get("stack")}')
services = snap.get('services') or []
updates = {}
missing = []
for item in services:
    svc = item.get('service')
    digests = item.get('repo_digests') or []
    if not svc:
        continue
    if not digests:
        missing.append(svc)
    else:
        updates[svc] = digests[0]
if missing:
    raise SystemExit('snapshot lacks immutable repo digests for service(s): ' + ', '.join(sorted(missing)))
if not updates:
    raise SystemExit('snapshot has no services with repo digests')
data = yaml.safe_load(compose_path.read_text(encoding='utf-8')) or {}
compose_services = data.get('services') or {}
current_image_services = {svc for svc, cfg in compose_services.items() if isinstance(cfg, dict) and cfg.get('image')}
missing_current = sorted(current_image_services - set(updates))
if missing_current:
    raise SystemExit('snapshot does not cover current image service(s): ' + ', '.join(missing_current))
for svc, image in updates.items():
    if svc not in compose_services:
        raise SystemExit(f'service {svc} not present in compose file')
    compose_services[svc]['image'] = image
compose_path.write_text(yaml.safe_dump(data, sort_keys=False), encoding='utf-8')
print('\n'.join(f'{svc} -> {image}' for svc, image in sorted(updates.items())))
PY
  echo "compose backup: $backup"
  (cd "$dir" && docker compose pull && docker compose up -d)
}

cmd_stack() {
  local sub="${1:-list}"
  if [ "$sub" = "list" ]; then
    for dir in /opt/stacks/*; do
      [ -f "$dir/docker-compose.yml" ] || continue
      basename "$dir"
    done
    return 0
  fi
  local name="${2:?stack name}"
  validate_stack_name "$name"
  if [ "$sub" = "digests" ]; then
    find "$STACK_DIGEST_DIR" -maxdepth 1 -type f -name "$name-*.json" 2>/dev/null | sort | tail -20
    return 0
  fi
  local dir="/opt/stacks/$name"
  [ -d "$dir" ] || err "no stack at $dir"
  case "$sub" in
    up)       gate "stack:up:$name"       "compose up at $dir"            bash -c 'cd "$1" && docker compose up -d' _ "$dir" ;;
    down)     gate "stack:down:$name"     "compose down at $dir"          bash -c 'cd "$1" && docker compose down' _ "$dir" ;;
    restart)  gate "stack:restart:$name"  "compose restart at $dir"       bash -c 'cd "$1" && docker compose restart' _ "$dir" ;;
    update)   gate "stack:update:$name"   "record image digests, preflight disk, pull+recreate at $dir" stack_update_impl "$name" "$dir" ;;
    rollback) need_root; gate "stack:rollback:$name" "rollback compose images from digest snapshot ${3:-latest}" stack_rollback_impl "$name" "$dir" "${3:-}" ;;
    logs)     (cd "$dir" && docker compose logs -f) ;;
    ps)       (cd "$dir" && docker compose ps) ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- net ----------
cmd_net() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    tailscale-up)
      need_root
      local key=""
      while [ $# -gt 0 ]; do
        case "$1" in --auth-key) key="$2"; shift 2 ;; *) shift ;; esac
      done
      if [ -n "$key" ]; then
        tailscale up --ssh --accept-routes --auth-key "$key"
      else
        tailscale up --ssh --accept-routes
      fi
      tailscale status
      local fqdn; fqdn="$(tailscale status --json 2>/dev/null | python3 -c 'import sys,json;d=json.load(sys.stdin);print(d["Self"]["DNSName"].rstrip(".") if d.get("Self") else "")' 2>/dev/null || true)"
      [ -n "$fqdn" ] && echo "HOMEOS_TAILNET=$fqdn" > /etc/default/caddy
      systemctl reload caddy 2>/dev/null || true
      ;;
    tailscale-down)
      need_root
      gate "net:tailscale-down" "tailscale down" tailscale down
      ;;
    caddy-reload)
      need_root
      systemctl reload caddy
      ;;
    caddy-test)
      caddy validate --config /etc/caddy/Caddyfile
      ;;
    *) usage; exit 2 ;;
  esac
}

# ---------- backup ----------
backup_require_env() {
  [ -f "$BACKUP_ENV" ] || err "no $BACKUP_ENV — rerun bootstrap"
  # shellcheck disable=SC1090
  source "$BACKUP_ENV"
  [ -n "${RESTIC_REPOSITORY:-}" ] || err "backup target unset — run: sudo homeos config backup target set /srv/nas/<label>"
  export RESTIC_REPOSITORY RESTIC_PASSWORD_FILE
}

backup_write_target() {
  local path="$1"
  python3 - "$BACKUP_ENV" "$path" <<'PY'
import pathlib, sys
env_path = pathlib.Path(sys.argv[1])
target = sys.argv[2]
lines = env_path.read_text(encoding="utf-8").splitlines() if env_path.exists() else []
found = False
out = []
for line in lines:
    if line.startswith("RESTIC_REPOSITORY="):
        out.append(f"RESTIC_REPOSITORY={target}")
        found = True
    else:
        out.append(line)
if not found:
    out.append(f"RESTIC_REPOSITORY={target}")
env_path.write_text("\n".join(out) + "\n", encoding="utf-8")
PY
}

cmd_backup() {
  local sub="${1:?target|run|verify|snapshots|forget|restore}"; shift || true
  case "$sub" in
    target)
      local action="${1:?set|show}"; shift || true
      case "$action" in
        set)
          local path="${1:?path required}"
          need_root
          mkdir -p "$(dirname "$BACKUP_ENV")"
          [ -f "$BACKUP_ENV" ] || printf 'RESTIC_REPOSITORY=\nRESTIC_PASSWORD_FILE=/etc/homeos/restic.pass\nBACKUP_PATHS="/srv /opt/stacks /home/admin"\n' > "$BACKUP_ENV"
          chmod 0600 "$BACKUP_ENV"
          mkdir -p "$path"
          backup_write_target "$path"
          backup_require_env
          preflight_backup_space
          restic snapshots >/dev/null 2>&1 || restic init
          echo "backup target: $path"
          ;;
        show)
          # shellcheck disable=SC1090
          [ -f "$BACKUP_ENV" ] && source "$BACKUP_ENV"
          echo "backup target: ${RESTIC_REPOSITORY:-unset}"
          ;;
        *) usage; exit 2 ;;
      esac
      ;;
    run)
      need_root
      backup_require_env
      preflight_backup_space
      /usr/local/sbin/homeos-backup
      ;;
    verify)
      need_root
      backup_require_env
      local subset=""
      while [ $# -gt 0 ]; do
        case "$1" in
          --read-data-subset) subset="${2:?percent required}"; shift 2 ;;
          --read-data-subset=*) subset="${1#*=}"; shift ;;
          *) usage; exit 2 ;;
        esac
      done
      if [ -n "$subset" ]; then
        [[ "$subset" =~ ^[0-9]+(\.[0-9]+)?%$ ]] || err "subset must be a percentage like 5%"
        restic check --read-data-subset "$subset"
      else
        restic check
      fi
      ;;
    snapshots)
      backup_require_env
      restic snapshots
      ;;
    forget)
      need_root
      backup_require_env
      restic forget --keep-daily 7 --keep-weekly 4 --keep-monthly 6 --prune
      ;;
    restore)
      need_root
      local snapshot="${1:?snapshot required}" path="${2:?restore target path required}"
      backup_require_env
      mkdir -p "$path"
      restic restore "$snapshot" --target "$path"
      ;;
    *) usage; exit 2 ;;
  esac
}

