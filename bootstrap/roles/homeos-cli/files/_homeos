#compdef homeos

_homeos() {
  local -a commands config_subs
  commands=(
    'status:show services, disks, containers, GPU'
    'doctor:run smoke tests'
    'diag:guided diagnostics'
    'log:view common logs'
    'init:guided first-run setup'
    'upgrade:routine maintenance updates'
    'secure:lock down SSH (key-only) + lock admin password'
    'config:configuration commands'
    'install:opt-in installer for AI/media/monitoring features'
    'audit:audit log of mutating commands'
  )
  config_subs=(
    'rerun-bootstrap:re-run Ansible playbook'
    'secrets:manage AI CLI credentials'
    'nas:manage USB NAS drives'
    'stack:manage docker compose stacks'
    'net:tailscale + caddy'
    'backup:restic backup config'
    'portal:toggle web portal (Homepage + Open WebUI + ttyd)'
    'cosmos:toggle Cosmos Cloud (alt portal: auth + container UI)'
    'gate:AI review provider (claude|openai|openrouter|ollama|none)'
  )

  case $words[2] in
    config)
      case $words[3] in
        secrets) _values 'op' list set get unset ;;
        nas)     _values 'op' list add remove ;;
        stack)   _values 'op' list up down restart update digests rollback logs ps ;;
        net)     _values 'op' tailscale-up tailscale-down caddy-reload caddy-test ;;
        backup)  _values 'op' target run verify snapshots forget restore ;;
        portal)  _values 'op' on off status ;;
        cosmos)  _values 'op' on off status ;;
        gate)    _values 'op' set show ;;
        *)       _describe 'config sub' config_subs ;;
      esac
      ;;
    init)    _values 'flag' --dry-run --yes --skip-secure --skip-tailscale --skip-secrets --skip-nas --skip-backup --auth-key --nas-device --backup-target ;;
    upgrade) _values 'flag' --check --skip-apt --skip-docker --skip-brew --skip-doctor ;;
    log)     _values 'target' summary bootstrap firstboot backup audit caddy docker tailscale cosmos portal stack\: ;;
    install) _values 'feature' ollama mcp-hub media-stack offsite-backup ai-keys monitoring image-gen voice --list ;;
    audit)   _values 'op' tail search show replay cosmos-events ;;
    *) _describe 'command' commands ;;
  esac
}
_homeos "$@"
