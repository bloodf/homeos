_homeos() {
  local cur prev words cword
  _init_completion || return
  local commands="status doctor diag log init upgrade secure config install audit"
  local config_subs="rerun-bootstrap secrets nas stack net backup portal cosmos gate"
  local installers="ollama mcp-hub media-stack offsite-backup ai-keys monitoring image-gen voice --list"
  case "${words[1]}" in
    config)
      case "${words[2]}" in
        secrets) COMPREPLY=( $(compgen -W "list set get unset" -- "$cur") ) ;;
        nas)     COMPREPLY=( $(compgen -W "list add remove" -- "$cur") ) ;;
        stack)   COMPREPLY=( $(compgen -W "list up down restart update digests rollback logs ps" -- "$cur") ) ;;
        net)     COMPREPLY=( $(compgen -W "tailscale-up tailscale-down caddy-reload caddy-test" -- "$cur") ) ;;
        backup)  COMPREPLY=( $(compgen -W "target run verify snapshots forget restore" -- "$cur") ) ;;
        portal)  COMPREPLY=( $(compgen -W "on off status" -- "$cur") ) ;;
        cosmos)  COMPREPLY=( $(compgen -W "on off status" -- "$cur") ) ;;
        gate)    COMPREPLY=( $(compgen -W "set show" -- "$cur") ) ;;
        *)       COMPREPLY=( $(compgen -W "$config_subs" -- "$cur") ) ;;
      esac
      ;;
    init)    COMPREPLY=( $(compgen -W "--dry-run --yes --skip-secure --skip-tailscale --skip-secrets --skip-nas --skip-backup --auth-key --nas-device --backup-target" -- "$cur") ) ;;
    upgrade) COMPREPLY=( $(compgen -W "--check --skip-apt --skip-docker --skip-brew --skip-doctor" -- "$cur") ) ;;
    log)     COMPREPLY=( $(compgen -W "--lines --follow summary bootstrap firstboot backup audit caddy docker tailscale cosmos portal stack:" -- "$cur") ) ;;
    install) COMPREPLY=( $(compgen -W "$installers" -- "$cur") ) ;;
    audit)   COMPREPLY=( $(compgen -W "tail search show replay cosmos-events" -- "$cur") ) ;;
    "")      COMPREPLY=( $(compgen -W "$commands" -- "$cur") ) ;;
  esac
}
complete -F _homeos homeos
