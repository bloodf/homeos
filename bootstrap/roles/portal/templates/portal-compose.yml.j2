# HomeOS Portal stack
# Toggled via `homeos config portal on|off|status`. Tailnet-only by default.
#
# Components:
#   homepage    :3001  — landing dashboard with live service widgets
#   open-webui  :3002  — chat UI for Claude/OpenAI/Gemini APIs (no terminal)
#   dockge      :5001  — docker-compose stack manager
#   filebrowser :8090  — web file manager for /srv + /home
#   ttyd-*      :7681-7688 — per-CLI web terminals (power users)

x-ttyd-common: &ttyd-common
  image: tsl0922/ttyd:latest
  restart: unless-stopped
  network_mode: host
  volumes:
    - {{ admin_home }}:/home/admin
    - /opt/tools:/opt/tools:ro
    - /srv/portal/launch.sh:/launch.sh:ro
    - {{ admin_home }}/.config/homeos/secrets.env:/secrets.env:ro
  environment:
    HOME: /home/admin
    USER: "{{ admin_user }}"
    TERM: xterm-256color
  user: "{{ admin_user_uid | default(1000) }}:{{ admin_user_gid | default(1000) }}"

services:
  # ─── Landing dashboard ──────────────────────────────────────────────────
  homepage:
    image: ghcr.io/gethomepage/homepage:latest
    container_name: homepage
    restart: unless-stopped
    ports:
      - "127.0.0.1:3001:3000"
    volumes:
      - /srv/portal/homepage:/app/config
      - /var/run/docker.sock:/var/run/docker.sock:ro
    environment:
      HOMEPAGE_ALLOWED_HOSTS: "*"
      LOG_LEVEL: info

  # ─── Chat UI for AI APIs (non-tech users) ───────────────────────────────
  open-webui:
    image: ghcr.io/open-webui/open-webui:main
    container_name: open-webui
    restart: unless-stopped
    ports:
      - "127.0.0.1:3002:8080"
    volumes:
      - /srv/portal/open-webui:/app/backend/data
    environment:
      WEBUI_AUTH: "True"
      WEBUI_NAME: "HomeOS AI"
      ENABLE_OLLAMA_API: "False"
      ENABLE_OPENAI_API: "True"
      # secrets file is bind-mounted; values picked from env at runtime
    env_file:
      - {{ admin_home }}/.config/homeos/secrets.env

  # ─── Docker Compose stack manager ───────────────────────────────────────
  dockge:
    image: louislam/dockge:1
    container_name: dockge
    restart: unless-stopped
    ports:
      - "127.0.0.1:5001:5001"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - /srv/portal/dockge:/app/data
      - /opt/stacks:/opt/stacks
    environment:
      DOCKGE_STACKS_DIR: /opt/stacks

  # ─── File manager ────────────────────────────────────────────────────────
  filebrowser:
    image: filebrowser/filebrowser:latest
    container_name: filebrowser
    restart: unless-stopped
    ports:
      - "127.0.0.1:8090:80"
    volumes:
      - /srv:/srv
      - {{ admin_home }}:/home-admin
      - /srv/portal/filebrowser/database.db:/database.db
      - /srv/portal/filebrowser/settings.json:/.filebrowser.json:ro
    user: "{{ admin_user_uid | default(1000) }}:{{ admin_user_gid | default(1000) }}"

  # ─── Per-tool web terminals ─────────────────────────────────────────────
  ttyd-claude:
    <<: *ttyd-common
    container_name: ttyd-claude
    command: ["ttyd", "-W", "-p", "7681", "-t", "titleFixed=Claude Code", "/launch.sh", "claude"]

  ttyd-codex:
    <<: *ttyd-common
    container_name: ttyd-codex
    command: ["ttyd", "-W", "-p", "7682", "-t", "titleFixed=Codex", "/launch.sh", "codex"]

  ttyd-gemini:
    <<: *ttyd-common
    container_name: ttyd-gemini
    command: ["ttyd", "-W", "-p", "7683", "-t", "titleFixed=Gemini", "/launch.sh", "gemini"]

  ttyd-cursor:
    <<: *ttyd-common
    container_name: ttyd-cursor
    command: ["ttyd", "-W", "-p", "7684", "-t", "titleFixed=Cursor Agent", "/launch.sh", "cursor-agent"]

  ttyd-opencode:
    <<: *ttyd-common
    container_name: ttyd-opencode
    command: ["ttyd", "-W", "-p", "7685", "-t", "titleFixed=OpenCode", "/launch.sh", "opencode"]

  ttyd-kimi:
    <<: *ttyd-common
    container_name: ttyd-kimi
    command: ["ttyd", "-W", "-p", "7686", "-t", "titleFixed=Kimi", "/launch.sh", "kimi"]

  ttyd-hermes:
    <<: *ttyd-common
    container_name: ttyd-hermes
    command: ["ttyd", "-W", "-p", "7687", "-t", "titleFixed=Hermes Agent", "/launch.sh", "hermes"]

  ttyd-shell:
    <<: *ttyd-common
    container_name: ttyd-shell
    command: ["ttyd", "-W", "-p", "7688", "-t", "titleFixed=Shell", "/launch.sh", "shell"]
