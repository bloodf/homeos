#!/usr/bin/env bash
# Launcher script run by ttyd inside each container.
# Sources secrets, then exec's the requested CLI.
set -e

if [ -r /secrets.env ]; then
  set -a
  # shellcheck disable=SC1091
  . /secrets.env
  set +a
fi

cd "$HOME"

case "${1:-shell}" in
  shell)        exec /usr/bin/env bash -i ;;
  claude)       exec claude ;;
  codex)        exec codex ;;
  gemini)       exec gemini ;;
  cursor-agent) exec cursor-agent ;;
  opencode)     exec opencode ;;
  kimi)         exec kimi ;;
  hermes)       exec /usr/local/bin/hermes ;;
  *)            exec "$@" ;;
esac
